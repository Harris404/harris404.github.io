# Transport NSW API Configuration
# Get your API key from: https://opendata.transport.nsw.gov.au/
NSW_TRANSPORT_API_KEY=your_nsw_transport_api_key_here
OPEN_TRANSPORT_API_KEY=your_nsw_transport_api_key_here

# Victoria Transport Open Data Portal
# Get your token from: https://discover.data.vic.gov.au/
VIC_TRANSPORT_TOKEN=your_vic_transport_token_here

# Google Gemini API (Optional - for ABS AI-powered queries)
# Get from: https://ai.google.dev/
GOOGLE_API_KEY=

# Project Configuration (update to your local path)
PROJECT_ROOT=/path/to/your/project
MCP_SERVERS_DIR=${PROJECT_ROOT}/mcp-servers

# Google Places API (For POI/restaurant search)
# Get key at: https://console.cloud.google.com/ > Enable "Places API (New)"
GOOGLE_PLACES_API_KEY=

# LLM API — Qwen via DashScope (Primary)
# Get from: https://dashscope.aliyun.com/
# Dual-model strategy: qwen-turbo for intent (cheap), qwen-plus for answers (quality)
DASHSCOPE_API_KEY=
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus           # Main model for answer generation
# LLM_MODEL_FAST=qwen-turbo     # Fast model for intent analysis (JSON)

# DeepSeek (legacy, still supported as fallback)
# DEEPSEEK_API_KEY=
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# HealthDirect NHSD FHIR API
# Registration: Email developer@digitalhealth.gov.au
HEALTHDIRECT_API_KEY=